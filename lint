#!/bin/bash
set -e

echo Running ruff check src
uv run ruff check --fix src
echo Running ruff check tests
uv run ruff check --fix tests
echo Running ruff format src tests
uv run ruff format src tests
echo Running pyright src tests
uv run pyright src tests
echo Running KeyboardInterrupt checks
uv run python scripts/check_keyboard_interrupt.py
echo Running sys.path.insert checks
uv run python scripts/check_sys_path.py
echo Running subprocess safety checks
uv run python scripts/check_subprocess_safety.py
echo Running orchestrator signature checks
uv run python scripts/check_orchestrator_signatures.py
echo Running message serialization checks
uv run python scripts/check_message_serialization.py
echo Running .fbuild path checks
uv run python scripts/check_fbuild_paths.py
echo Linting complete!
exit 0
