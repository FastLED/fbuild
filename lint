#!/bin/bash
""":"
exec uv run python "$0" "$@"
"""

import subprocess
import sys


def run(cmd: str) -> None:
    print(f"Running {cmd}")
    result = subprocess.run(cmd.split())
    if result.returncode != 0:
        sys.exit(result.returncode)


def run_uv(cmd: str) -> None:
    run(f"uv run {cmd}")


def main() -> int:
    run_uv("ruff check --fix src")
    run_uv("ruff check --fix tests")
    run_uv("ruff format src tests")
    run_uv("pyright src tests")
    run_uv("python scripts/check_keyboard_interrupt.py")
    run_uv("python scripts/check_sys_path.py")
    run_uv("python scripts/check_subprocess_safety.py")
    run_uv("python scripts/check_orchestrator_signatures.py")
    run_uv("python scripts/check_message_serialization.py")
    run_uv("python scripts/check_fbuild_paths.py")
    print("Linting complete!")
    return 0


if __name__ == "__main__":
    sys.exit(main())
