#!/bin/bash
set -e

# Run workspace linting: rustfmt check + clippy.
#
# Usage:
#   ./lint              # full workspace lint
#   ./lint --fix        # auto-fix formatting + clippy
#   ./lint <file.rs>    # single-file rustfmt + per-crate clippy

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

FIX=false
FILE=""
ARGS=()

for arg in "$@"; do
    if [ "$arg" = "--fix" ]; then
        FIX=true
    else
        ARGS+=("$arg")
    fi
done

# Check if first remaining arg is a .rs file
if [ ${#ARGS[@]} -gt 0 ] && [[ "${ARGS[0]}" == *.rs ]]; then
    FILE="${ARGS[0]}"
fi

# Detect crate from file path
detect_crate() {
    local normalized="${1//\\//}"
    if [[ "$normalized" == *crates/* ]]; then
        local after="${normalized#*crates/}"
        local crate_dir="${after%%/*}"
        if [ -n "$crate_dir" ]; then
            echo "$crate_dir"
            return
        fi
    fi
    echo ""
}

# --fix mode
if $FIX; then
    uv run cargo fmt --all
    if [ -z "$FILE" ]; then
        exec uv run cargo clippy --workspace --all-targets -- -D warnings
    fi
fi

# Single file mode
if [ -n "$FILE" ]; then
    FILE="$(cd "$SCRIPT_DIR" && realpath "$FILE" 2>/dev/null || echo "$FILE")"
    if [ ! -f "$FILE" ]; then
        echo "File not found: $FILE" >&2
        exit 1
    fi
    uv run rustfmt "$FILE"
    CRATE="$(detect_crate "$FILE")"
    if [ -n "$CRATE" ]; then
        exec uv run cargo clippy -p "$CRATE" --all-targets -- -D warnings
    else
        exec uv run cargo clippy --workspace --all-targets -- -D warnings
    fi
fi

# Full workspace mode
uv run cargo fmt --all --check || {
    echo "Formatting issues found. Run './lint --fix' to auto-fix." >&2
    exit 1
}
exec uv run cargo clippy --workspace --all-targets -- -D warnings
