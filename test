#!/bin/bash
""":"
exec uv run python "$0" "$@"
"""

import os
import subprocess
import sys


def run(cmd: list[str]) -> None:
    result = subprocess.run(cmd)
    if result.returncode != 0:
        sys.exit(result.returncode)


def main() -> int:
    os.environ["FBUILD_DEV_MODE"] = "1"

    full_mode = "--full" in sys.argv

    print("========================================")
    print("Running unit tests (parallel)")
    print("========================================")
    run(["uv", "run", "--group", "test", "pytest", "-n", "auto", "tests/unit", "-v", "--durations=0"])

    if full_mode:
        print()
        print("========================================")
        print("Running integration tests (serial)")
        print("========================================")
        run(["uv", "run", "--group", "test", "pytest", "tests/integration", "-v", "--durations=0"])
    else:
        print()
        print("========================================")
        print("Skipping integration tests (use --full to run them)")
        print("========================================")

    print()
    print("========================================")
    print("All tests completed successfully!")
    print("========================================")
    return 0


if __name__ == "__main__":
    sys.exit(main())
