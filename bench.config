# bench.config — sourced by .github/workflows/benchmark.yml
#
# This file parameterizes the benchmark run. Edit, commit, push — the workflow
# triggers on every push to bench/fastled-examples and re-reads this file.
#
# Shell syntax: variable assignments only. No substitution, no command output.

# Board to compile all examples for.
# Must be a board known to FastLED's compile script. Prefer one in fbuild's
# FBUILD_BOARDS list for apples-to-apples with CI: uno, esp32dev, esp32s3, etc.
BOARD=uno

# FastLED git ref to benchmark (branch name, tag, or SHA). master = latest.
FASTLED_REF=master

# Compile args after the board. 'all' compiles every example; or pass a
# space-separated subset like 'Blink DemoReel100'.
EXAMPLES=all

# Cache-bust. Any non-empty value forces a cold fbuild cache. Bump this
# (e.g., timestamp) before a push to measure cold-cache wall-clock. Leave
# empty for warm runs.
CACHE_BUST=iter4-zccache-store
