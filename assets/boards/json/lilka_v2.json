{
  "id": "lilka_v2",
  "name": "Lilka v2",
  "platform": "espressif32",
  "mcu": "ESP32S3",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 16777216,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Anderson & friends",
  "url": "https://github.com/and3rson/lilka",
  "connectivity": [
    "bluetooth",
    "wifi"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "esp-bridge": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {},
      "esp-builtin": {}
    }
  },
  "build": {
    "arduino": {
      "memory_type": "qio_opi",
      "partitions": "default_16MB.csv"
    },
    "core": "esp32",
    "extra_flags": [
      "-DARDUINO_LILKA",
      "-DLILKA_VERSION=2",
      "-DARDUINO_USB_MODE=1",
      "-DARDUINO_USB_CDC_ON_BOOT=1",
      "-DARDUINO_RUNNING_CORE=1",
      "-DARDUINO_EVENT_RUNNING_CORE=1",
      "-DBOARD_HAS_PSRAM"
    ],
    "f_cpu": "240000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "hwids": [
      [
        "0x239A",
        "0x8145"
      ],
      [
        "0x239A",
        "0x0145"
      ],
      [
        "0x239A",
        "0x8146"
      ]
    ],
    "mcu": "esp32s3",
    "variant": "esp32s3"
  },
  "upload": {
    "flash_size": "16MB",
    "maximum_ram_size": 327680,
    "maximum_size": 16777216,
    "require_upload_port": true,
    "speed": 460800
  }
}
