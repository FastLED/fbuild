{
  "id": "bee_motion_s3",
  "name": "Smart Bee Motion S3",
  "platform": "espressif32",
  "mcu": "ESP32S3",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 8388608,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Smart Bee",
  "url": "https://github.com/strid3r21/BeeMotionS3/",
  "connectivity": [
    "bluetooth",
    "wifi"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "esp-bridge": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {},
      "esp-builtin": {}
    }
  },
  "build": {
    "core": "esp32",
    "extra_flags": [
      "-DARDUINO_BeeMotionS3",
      "-DARDUINO_RUNNING_CORE=1",
      "-DARDUINO_EVENT_RUNNING_CORE=1",
      "-DARDUINO_USB_CDC_ON_BOOT=1"
    ],
    "f_cpu": "240000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "hwids": [
      [
        "0x303A",
        "0x8113"
      ]
    ],
    "mcu": "esp32s3",
    "variant": "Bee_Motion_S3"
  },
  "upload": {
    "flash_size": "8MB",
    "maximum_ram_size": 327680,
    "maximum_size": 8388608,
    "use_1200bps_touch": true,
    "wait_for_upload_port": true,
    "require_upload_port": true,
    "speed": 460800
  }
}
