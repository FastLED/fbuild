{
  "board": "rpipico",
  "mcu": "rp2040",
  "platform": "rp",
  "source": "PlatformIO rp platform (extracted from platform_configs)",
  "compiler_flags": {
    "common": [
      "-march=armv6-m",
      "-mcpu=cortex-m0plus",
      "-mthumb",
      "-ffunction-sections",
      "-fdata-sections",
      "-fno-exceptions",
      "-Wno-error=unused-function",
      "-Wno-error=unused-variable",
      "-Wno-error=deprecated-declarations",
      "-Wno-unused-parameter",
      "-Wno-sign-compare",
      "-MMD"
    ],
    "c": [
      "-std=gnu17"
    ],
    "cxx": [
      "-std=gnu++17",
      "-fno-rtti",
      "-fno-exceptions",
      "-fno-threadsafe-statics"
    ]
  },
  "defines": {
    "ARDUINO_ARCH_RP2040": "1",
    "F_CPU": "133000000L",
    "PICO_BOARD": "1",
    "PICO_BUILD": "1",
    "PICO_NO_HARDWARE": "1",
    "PICO_ON_DEVICE": "1",
    "TARGET_RP2040": "1",
    "PICO_RP2040": "1",
    "CFG_TUSB_MCU": "OPT_MCU_RP2040",
    "LWIP_IPV4": "1",
    "LWIP_IPV6": "0",
    "RASPBERRY_PI_PICO": "1"
  },
  "linker_flags": [
    "-march=armv6-m",
    "-mcpu=cortex-m0plus",
    "-mthumb",
    "-Wl,--cref",
    "-Wl,--check-sections",
    "-Wl,--gc-sections",
    "-Wl,--unresolved-symbols=report-all",
    "-Wl,--warn-common",
    "-Wl,--warn-section-align",
    "-Wl,--wrap=malloc",
    "-Wl,--wrap=calloc",
    "-Wl,--wrap=realloc",
    "-Wl,--wrap=free",
    "-u",
    "_printf_float",
    "-u",
    "_scanf_float"
  ],
  "linker_libs": [
    "-lgcc",
    "-lstdc++",
    "-lm",
    "-lc"
  ]
}
