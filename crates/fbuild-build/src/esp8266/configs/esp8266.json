{
  "name": "ESP8266",
  "description": "Configuration for ESP8266 MCU (Xtensa LX106)",
  "architecture": "xtensa-lx106",

  "compiler_flags": {
    "common": [
      "-mlongcalls",
      "-mtext-section-literals",
      "-falign-functions=4",
      "-ffunction-sections",
      "-fdata-sections",
      "-Wall",
      "-Wextra",
      "-Wno-unused-parameter",
      "-MMD"
    ],
    "c": [
      "-std=gnu17"
    ],
    "cxx": [
      "-std=gnu++17",
      "-fno-rtti",
      "-fno-exceptions"
    ]
  },

  "linker_flags": [
    "-nostdlib",
    "-Wl,--no-check-sections",
    "-Wl,--gc-sections",
    "-Wl,-static",
    "-Wl,-wrap,system_restart_local",
    "-Wl,-wrap,spi_flash_read",
    "-u", "app_entry",
    "-u", "_printf_float",
    "-u", "_scanf_float"
  ],

  "linker_libs": [
    "-lhal",
    "-lphy",
    "-lpp",
    "-lnet80211",
    "-llwip2-536-feat",
    "-lwpa",
    "-lcrypto",
    "-lmain",
    "-lwps",
    "-lbearssl",
    "-lespnow",
    "-lsmartconfig",
    "-lairkiss",
    "-lwpa2",
    "-lstdc++",
    "-lm",
    "-lc",
    "-lgcc"
  ],

  "objcopy": {
    "output_format": "binary",
    "remove_sections": [".eeprom"]
  },

  "profiles": {
    "release": {
      "compile_flags": ["-Os"],
      "link_flags": []
    },
    "quick": {
      "compile_flags": ["-Os"],
      "link_flags": []
    }
  },

  "defines": [
    "ESP8266",
    "ARDUINO_ARCH_ESP8266",
    "LWIP_OPEN_SRC",
    ["TCP_MSS", "536"],
    ["LWIP_FEATURES", "1"],
    ["LWIP_IPV6", "0"],
    "__ets__",
    "ICACHE_FLASH",
    "_GNU_SOURCE",
    ["NONOSDK305", "1"],
    "VTABLES_IN_FLASH",
    ["MMU_IRAM_SIZE", "0xC000"],
    ["MMU_ICACHE_SIZE", "0x8000"]
  ],

  "esptool": {
    "chip": "esp8266",
    "default_flash_mode": "dio",
    "default_flash_freq": "40m",
    "default_flash_size": "4MB",
    "default_baud": 115200
  }
}
