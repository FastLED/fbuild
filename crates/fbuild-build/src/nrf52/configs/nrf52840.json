{
  "name": "NRF52840",
  "description": "Nordic NRF52840 (ARM Cortex-M4F)",
  "architecture": "arm-cortex-m4f",
  "compiler_flags": {
    "common": ["-mcpu=cortex-m4", "-mthumb", "-mfloat-abi=hard", "-mfpu=fpv4-sp-d16", "-mabi=aapcs", "-Wall", "-Wextra", "-Wno-unused-parameter", "-ffunction-sections", "-fdata-sections", "-fno-strict-aliasing", "-fno-builtin", "-fshort-enums", "-MMD"],
    "c": ["-std=gnu11"],
    "cxx": ["-std=gnu++17", "-fno-exceptions", "-fno-rtti", "-fno-threadsafe-statics"]
  },
  "linker_flags": ["-mcpu=cortex-m4", "-mthumb", "-mfloat-abi=hard", "-mfpu=fpv4-sp-d16", "-Wl,--gc-sections", "-Wl,--print-memory-usage", "--specs=nano.specs", "--specs=nosys.specs"],
  "linker_libs": ["-lgcc", "-lstdc++", "-lm", "-lc", "-lnosys"],
  "objcopy": {"output_format": "ihex", "remove_sections": [".eeprom"]},
  "profiles": {
    "release": {"compile_flags": ["-Os", "-flto", "-fno-fat-lto-objects"], "link_flags": ["-flto", "-fuse-linker-plugin"]},
    "quick": {"compile_flags": ["-Os"], "link_flags": []}
  },
  "defines": [
    ["ARDUINO", "10808"],
    "NRF52840_XXAA",
    "NRF52_SERIES",
    "USE_TINYUSB",
    "USBCON",
    "SOFTDEVICE_PRESENT",
    "ARDUINO_NRF52_ADAFRUIT",
    "DX_CC_TEE",
    ["LFS_NAME_MAX", "64"],
    ["CFG_DEBUG", "0"],
    ["CFG_LOGGER", "0"],
    ["CFG_SYSVIEW", "0"],
    ["ARDUINO_BSP_VERSION", "\"1.6.1\""]
  ]
}
