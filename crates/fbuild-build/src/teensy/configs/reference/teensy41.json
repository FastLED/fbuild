{
  "board": "teensy41",
  "mcu": "imxrt1062",
  "source": "PlatformIO teensy platform (extracted from SCons builder environment)",

  "linker_flags": [
    "-mcpu=cortex-m7",
    "-mthumb",
    "-mfloat-abi=hard",
    "-mfpu=fpv5-d16",
    "-Wl,--gc-sections",
    "-Wl,--print-memory-usage"
  ],

  "linker_libs": [
    "-lgcc",
    "-lstdc++",
    "-lm",
    "-lc"
  ]
}
