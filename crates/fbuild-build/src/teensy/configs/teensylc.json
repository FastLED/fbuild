{
  "name": "Teensy LC",
  "description": "Configuration for Teensy LC (ARM Cortex-M0+, MKL26Z64)",
  "architecture": "arm-cortex-m0plus",

  "compiler_flags": {
    "common": [
      "-mcpu=cortex-m0plus",
      "-mthumb",
      "-Wall",
      "-Wextra",
      "-Wno-unused-parameter",
      "-ffunction-sections",
      "-fdata-sections",
      "-MMD"
    ],
    "c": [
      "-std=gnu11"
    ],
    "cxx": [
      "-std=gnu++14",
      "-fno-exceptions",
      "-fno-rtti",
      "-felide-constructors",
      "-fno-threadsafe-statics"
    ]
  },

  "linker_flags": [
    "-mcpu=cortex-m0plus",
    "-mthumb",
    "-Wl,--gc-sections",
    "-Wl,--relax",
    "-Wl,--print-memory-usage",
    "--specs=nano.specs"
  ],

  "linker_libs": [
    "-lgcc",
    "-lstdc++",
    "-lm",
    "-lc"
  ],

  "objcopy": {
    "output_format": "ihex",
    "remove_sections": [".eeprom"]
  },

  "profiles": {
    "release": {
      "compile_flags": ["-Os", "-flto", "-fno-fat-lto-objects"],
      "link_flags": ["-flto", "-fuse-linker-plugin"]
    },
    "quick": {
      "compile_flags": ["-Os"],
      "link_flags": []
    }
  },

  "teensy_loader": {
    "wait_flag": "-w",
    "verbose_flag": "-v",
    "timeout_secs": 60
  }
}
