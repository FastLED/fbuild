{
  "name": "Teensy 4.x",
  "description": "Configuration for Teensy 4.0/4.1 (ARM Cortex-M7, iMXRT1062)",
  "architecture": "arm-cortex-m7",

  "compiler_flags": {
    "common": [
      "-mcpu=cortex-m7",
      "-mthumb",
      "-mfloat-abi=hard",
      "-mfpu=fpv5-d16",
      "-Wall",
      "-Wextra",
      "-Wno-unused-parameter",
      "-ffunction-sections",
      "-fdata-sections",
      "-MMD"
    ],
    "c": [
      "-std=gnu11"
    ],
    "cxx": [
      "-std=gnu++17",
      "-fno-exceptions",
      "-fno-rtti",
      "-felide-constructors",
      "-fno-threadsafe-statics"
    ]
  },

  "linker_flags": [
    "-mcpu=cortex-m7",
    "-mthumb",
    "-mfloat-abi=hard",
    "-mfpu=fpv5-d16",
    "-Wl,--gc-sections",
    "-Wl,--print-memory-usage"
  ],

  "linker_libs": [
    "-larm_cortexM7lfsp_math",
    "-lgcc",
    "-lstdc++",
    "-lm",
    "-lc"
  ],

  "objcopy": {
    "output_format": "ihex",
    "remove_sections": [".eeprom"]
  },

  "profiles": {
    "release": {
      "compile_flags": ["-Os", "-flto=auto", "-fno-fat-lto-objects"],
      "link_flags": ["-flto=auto", "-fuse-linker-plugin"]
    },
    "quick": {
      "compile_flags": ["-Os"],
      "link_flags": []
    }
  },

  "defines": [
    ["TEENSYDUINO", "159"],
    ["USB_SERIAL", "1"],
    ["LAYOUT_US_ENGLISH", "1"],
    ["ARDUINO", "10819"]
  ],

  "teensy_loader": {
    "wait_flag": "-w",
    "verbose_flag": "-v",
    "timeout_secs": 60
  }
}
