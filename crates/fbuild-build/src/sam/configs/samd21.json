{
  "name": "SAMD21",
  "description": "Atmel SAMD21 (ARM Cortex-M0+)",
  "architecture": "arm-cortex-m0plus",
  "compiler_flags": {
    "common": ["-mcpu=cortex-m0plus", "-mthumb", "-Wall", "-Wextra", "-Wno-unused-parameter", "-Wno-expansion-to-defined", "-ffunction-sections", "-fdata-sections", "-nostdlib", "-MMD", "--param", "max-inline-insns-single=500"],
    "c": ["-std=gnu11"],
    "cxx": ["-std=gnu++11", "-fno-exceptions", "-fno-rtti", "-fno-threadsafe-statics"]
  },
  "linker_flags": ["-mcpu=cortex-m0plus", "-mthumb", "-Wl,--gc-sections", "-Wl,--check-sections", "-Wl,--unresolved-symbols=report-all", "-Wl,--warn-common", "-Wl,--warn-section-align", "-Wl,--print-memory-usage", "--specs=nano.specs", "--specs=nosys.specs"],
  "linker_libs": ["-lgcc", "-lstdc++", "-lm", "-lc"],
  "objcopy": {"output_format": "binary", "remove_sections": [".eeprom"]},
  "profiles": {
    "release": {"compile_flags": ["-Os"], "link_flags": []},
    "quick": {"compile_flags": ["-Os"], "link_flags": []}
  },
  "defines": [["ARDUINO", "10808"]]
}
