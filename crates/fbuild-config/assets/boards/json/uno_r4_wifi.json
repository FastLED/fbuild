{
  "build": {
    "core": "arduino",
    "extra_flags": "-DF_CPU=48000000L -DARDUINO_UNOR4_WIFI -DNO_USB -DBACKTRACE_SUPPORT -DARDUINO_ARCH_RENESAS -DARDUINO_FSP -D_XOPEN_SOURCE=700 -DCFG_TUSB_MCU=OPT_MCU_RAXXX -D_RA_CORE=CM4 -D_RENESAS_RA_",
    "variant": "UNOWIFIR4"
  },
  "debug": {
    "tools": {
      "jlink": {},
      "cmsis-dap": {
        "onboard": true,
        "default": true
      }
    }
  },
  "fcpu": 48000000,
  "frameworks": [
    "arduino",
    "fsp",
    "cmsis"
  ],
  "id": "uno_r4_wifi",
  "mcu": "RA4M1",
  "name": "Arduino Uno R4 WiFi",
  "platform": "renesas-ra",
  "ram": 32768,
  "rom": 262144,
  "url": "https://docs.arduino.cc/hardware/uno-r4-wifi",
  "vendor": "Arduino"
}
