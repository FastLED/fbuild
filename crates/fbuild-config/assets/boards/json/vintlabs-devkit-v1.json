{
  "id": "vintlabs-devkit-v1",
  "name": "VintLabs ESP32 Devkit",
  "platform": "espressif32",
  "mcu": "ESP32",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 4194304,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "VintLabs",
  "url": "https://www.vintlabs.com/product/vintlabs-esp32-wroom32-iot-8x2a-pwm-driver-development-kit-4mb-flash-wifi-bluetooth/",
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_ESP32_DEV",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "40000000L",
    "flash_mode": "dio",
    "variant": "vintlabsdevkitv1",
    "arduino": {
      "ldscript": "esp32_out.ld"
    }
  },
  "upload": {
    "flash_size": "4MB",
    "speed": 460800,
    "require_upload_port": true
  }
}
