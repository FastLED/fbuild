{
  "id": "nano32",
  "name": "MakerAsia Nano32",
  "platform": "espressif32",
  "mcu": "ESP32",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 4194304,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "MakerAsia",
  "url": "http://iot-bits.com/nano32-esp32-development-board",
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "build": {
    "extra_flags": "-DARDUINO_NANO32",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "40000000L",
    "flash_mode": "dio",
    "variant": "nano32",
    "arduino": {
      "ldscript": "esp32_out.ld"
    }
  },
  "upload": {
    "flash_size": "4MB",
    "speed": 460800,
    "require_upload_port": true
  }
}
