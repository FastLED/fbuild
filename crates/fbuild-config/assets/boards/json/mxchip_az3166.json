{
  "id": "mxchip_az3166",
  "name": "Microsoft Azure IoT Development Kit (MXChip AZ3166)",
  "platform": "ststm32",
  "mcu": "STM32F412ZGT6",
  "fcpu": 100000000,
  "ram": 262144,
  "rom": 1048576,
  "frameworks": [
    "arduino",
    "cmsis",
    "stm32cube",
    "libopencm3"
  ],
  "vendor": "MXChip",
  "url": "https://microsoft.github.io/azure-iot-developer-kit/",
  "connectivity": [
    "can",
    "wifi"
  ],
  "debug": {
    "tools": {
      "blackmagic": {},
      "jlink": {},
      "stlink": {
        "onboard": true,
        "default": true
      },
      "cmsis-dap": {}
    }
  },
  "build": {
    "extra_flags": "-DSTM32F4 -DSTM32F412Zx -DARDUINO_MXCHIP_AZ3166 -DARDUINO_ARCH_STM32F4",
    "core": "arduino",
    "f_cpu": "100000000L",
    "mcu": "stm32f412zgt6",
    "variant": "MXChip_AZ3166",
    "arduino": {
      "ldscript": "AZ3166.ld"
    }
  },
  "upload": {
    "protocol": "stlink"
  }
}
