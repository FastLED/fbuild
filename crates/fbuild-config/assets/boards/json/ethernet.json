{
  "id": "ethernet",
  "name": "Arduino Ethernet",
  "platform": "atmelavr",
  "mcu": "ATMEGA328P",
  "fcpu": 16000000,
  "ram": 2048,
  "rom": 32256,
  "frameworks": [
    "arduino"
  ],
  "vendor": "Arduino",
  "url": "https://www.arduino.cc/en/Main/ArduinoBoardEthernet",
  "connectivity": [
    "ethernet"
  ],
  "debug": {
    "tools": {
      "simavr": {},
      "avr-stub": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_AVR_ETHERNET",
    "core": "arduino",
    "f_cpu": "16000000L",
    "mcu": "atmega328p",
    "variant": "ethernet"
  },
  "upload": {
    "protocol": "arduino",
    "speed": 115200,
    "require_upload_port": true
  }
}
