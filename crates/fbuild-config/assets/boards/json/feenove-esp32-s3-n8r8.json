{
  "id": "feenove-esp32-s3-n8r8",
  "name": "Freenove ESP32-S3 WROOM N8R8 (8MB Flash / 8MB PSRAM)",
  "platform": "espressif32",
  "mcu": "ESP32S3",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 8388608,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Freenove",
  "url": "https://github.com/Freenove/Freenove_ESP32_S3_WROOM_Board",
  "connectivity": [
    "wifi",
    "bluetooth"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "esp-bridge": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {},
      "esp-builtin": {
        "onboard": true,
        "default": true
      }
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_ESP32S3_DEV -DARDUINO_RUNNING_CORE=1 -DARDUINO_EVENT_RUNNING_CORE=1 -DBOARD_HAS_PSRAM",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32s3",
    "f_flash": "80000000L",
    "flash_mode": "dio",
    "variant": "esp32s3",
    "arduino": {
      "partitions": "default_8MB.csv",
      "memory_type": "dio_opi"
    }
  },
  "upload": {
    "flash_size": "8MB",
    "speed": 921600,
    "require_upload_port": true
  }
}
