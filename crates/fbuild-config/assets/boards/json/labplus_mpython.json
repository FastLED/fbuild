    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "variant": "mpython",
    "arduino": {
      "ldscript": "esp32_out.ld",
      "partitions": "huge_app.csv"
