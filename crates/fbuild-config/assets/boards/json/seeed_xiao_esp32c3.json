      "esp-builtin": {},
      "esp-prog": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-ocd": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-jtag-tiny": {},
