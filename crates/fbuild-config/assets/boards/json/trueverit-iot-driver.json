{
  "id": "trueverit-iot-driver",
  "name": "Trueverit ESP32 Universal IoT Driver",
  "platform": "espressif32",
  "mcu": "ESP32",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 4194304,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Trueverit",
  "url": "https://trueverit.com/",
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_Trueverit_ESP32_Universal_IoT_Driver",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "40000000L",
    "flash_mode": "dio",
    "variant": "esp32-trueverit-iot-driver",
    "arduino": {
      "ldscript": "esp32_out.ld"
    }
  },
  "upload": {
    "flash_size": "4MB",
    "speed": 460800,
    "require_upload_port": true
  }
}
