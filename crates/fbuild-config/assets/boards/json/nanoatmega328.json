{
  "id": "nanoatmega328",
  "name": "Arduino Nano ATmega328",
  "platform": "atmelavr",
  "mcu": "ATMEGA328P",
  "fcpu": 16000000,
  "ram": 2048,
  "rom": 30720,
  "frameworks": [
    "arduino"
  ],
  "vendor": "Arduino",
  "url": "https://www.arduino.cc/en/Main/ArduinoBoardNano",
  "debug": {
    "tools": {
      "simavr": {},
      "avr-stub": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_AVR_NANO",
    "core": "arduino",
    "f_cpu": "16000000L",
    "mcu": "atmega328p",
    "variant": "eightanaloginputs"
  },
  "upload": {
    "protocol": "arduino",
    "speed": 57600,
    "require_upload_port": true
  }
}
