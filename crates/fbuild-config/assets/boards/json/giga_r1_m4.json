{
  "id": "giga_r1_m4",
  "name": "Arduino Giga R1 (M4 core)",
  "platform": "ststm32",
  "mcu": "STM32H747XIH6",
  "fcpu": 480000000,
  "ram": 294248,
  "rom": 1048576,
  "frameworks": [
    "arduino"
  ],
  "vendor": "Arduino",
  "url": "https://docs.arduino.cc/hardware/giga-r1-wifi",
  "connectivity": [
    "bluetooth",
    "wifi"
  ],
  "debug": {
    "tools": {
      "jlink": {},
      "stlink": {},
      "cmsis-dap": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_GIGA -DARDUINO_GIGA_M4 -DGIGA_PINS",
    "core": "arduino",
    "f_cpu": "480000000L",
    "mcu": "stm32h747xih6",
    "variant": "GENERIC_STM32H747_M4",
    "arduino": {
      "ldscript": "linker_script.ld"
    }
  },
  "upload": {
    "protocol": "dfu",
    "require_upload_port": true
  }
}
