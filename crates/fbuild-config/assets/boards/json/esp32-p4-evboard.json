{
  "id": "esp32-p4-evboard",
  "name": "Espressif ESP32-P4 Function EV Board (ES pre rev.300)",
  "platform": "espressif32",
  "mcu": "ESP32P4",
  "fcpu": 360000000,
  "ram": 512000,
  "rom": 16777216,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Espressif",
  "url": "https://docs.espressif.com/projects/esp-dev-kits/en/latest/esp32p4/esp32-p4-function-ev-board/index.html",
  "connectivity": [
    "bluetooth",
    "openthread"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "esp-bridge": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {},
      "esp-builtin": {}
    }
  },
  "build": {
    "extra_flags": "-DBOARD_HAS_PSRAM",
    "core": "esp32",
    "f_cpu": "360000000L",
    "mcu": "esp32p4",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "variant": "esp32p4"
  },
  "upload": {
    "flash_size": "16MB",
    "speed": 1500000,
    "require_upload_port": true
  }
}
