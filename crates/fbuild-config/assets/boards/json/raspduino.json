{
  "id": "raspduino",
  "name": "BitWizard Raspduino",
  "platform": "atmelavr",
  "mcu": "ATMEGA328P",
  "fcpu": 16000000,
  "ram": 2048,
  "rom": 30720,
  "frameworks": [
    "arduino"
  ],
  "vendor": "BitWizard",
  "url": "http://www.bitwizard.nl/wiki/index.php/Raspduino",
  "debug": {
    "tools": {
      "simavr": {},
      "avr-stub": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_AVR_RASPDUINO",
    "core": "arduino",
    "f_cpu": "16000000L",
    "mcu": "atmega328p",
    "variant": "standard"
  },
  "upload": {
    "protocol": "arduino",
    "speed": 57600,
    "require_upload_port": true
  }
}
