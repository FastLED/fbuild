  "frameworks": [
    "arduino",
    "espidf"
  ],
  "id": "esp32s3usbotg",
  "mcu": "ESP32S3",
  "name": "Espressif ESP32-S3-USB-OTG",
  "platform": "espressif32",
  "ram": 327680,
  "rom": 8388608,
  "upload": {
    "flash_size": "8MB",
