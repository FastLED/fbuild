{
  "id": "watchy",
  "name": "SQFMI Watchy v2.0",
  "platform": "espressif32",
  "mcu": "ESP32",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 4194304,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "SQFMI",
  "url": "https://watchy.sqfmi.com/",
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_WATCHY",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "40000000L",
    "flash_mode": "dio",
    "variant": "watchy",
    "arduino": {
      "ldscript": "esp32_out.ld",
      "partitions": "huge_app.csv"
    }
  },
  "upload": {
    "flash_size": "4MB",
    "speed": 460800,
    "require_upload_port": true
  }
}
