{
  "id": "esp32-s2-saola-1",
  "name": "Espressif ESP32-S2-Saola-1",
  "platform": "espressif32",
  "mcu": "ESP32S2",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 4194304,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Espressif",
  "url": "https://docs.espressif.com/projects/esp-idf/en/latest/esp32s2/hw-reference/esp32s2/user-guide-saola-1-v1.2.html",
  "connectivity": [
    "wifi"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_ESP32S2_DEV",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32s2",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "variant": "esp32s2",
    "arduino": {
      "ldscript": "esp32s2_out.ld"
    }
  },
  "upload": {
    "flash_size": "4MB",
    "speed": 460800,
    "require_upload_port": true
  }
}
