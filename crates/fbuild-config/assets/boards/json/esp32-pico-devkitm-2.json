{
  "id": "esp32-pico-devkitm-2",
  "name": "Espressif ESP32-PICO-DevKitM-2",
  "platform": "espressif32",
  "mcu": "ESP32",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 8388608,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Espressif Systems",
  "url": "https://docs.espressif.com/projects/esp-idf/en/latest/esp32/hw-reference/esp32/get-started-pico-devkitm-2.html",
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "build": {
    "extra_flags": "-DARDUINO_ESP32_PICO_DEVKITM_2 -DBOARD_HAS_PSRAM",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "variant": "esp32",
    "arduino": {
      "ldscript": "esp32_out.ld"
    }
  },
  "upload": {
    "flash_size": "8MB",
    "speed": 921600,
    "require_upload_port": true
  }
}
