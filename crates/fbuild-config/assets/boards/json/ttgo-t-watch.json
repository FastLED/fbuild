{
  "id": "ttgo-t-watch",
  "name": "TTGO T-Watch",
  "platform": "espressif32",
  "mcu": "ESP32",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 16777216,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "TTGO",
  "url": "https://github.com/Xinyuan-LilyGO/TTGO-T-Watch",
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "build": {
    "extra_flags": "-DARDUINO_TWATCH_BASE -DBOARD_HAS_PSRAM -mfix-esp32-psram-cache-issue -mfix-esp32-psram-cache-strategy=memw",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "40000000L",
    "flash_mode": "dio",
    "variant": "twatch",
    "arduino": {
      "ldscript": "esp32_out.ld",
      "partitions": "default_16MB.csv"
    }
  },
  "upload": {
    "flash_size": "16MB",
    "speed": 2000000,
    "require_upload_port": true
  }
}
