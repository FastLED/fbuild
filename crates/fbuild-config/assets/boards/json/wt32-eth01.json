{
  "id": "wt32-eth01",
  "name": "Wireless-Tag WT32-ETH01 Ethernet Module",
  "platform": "espressif32",
  "mcu": "ESP32",
  "fcpu": 240000000,
  "ram": 327680,
  "rom": 4194304,
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "vendor": "Wireless-Tag",
  "url": "http://www.wireless-tag.com/portfolio/wt32-eth01/",
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "debug": {
    "tools": {
      "cmsis-dap": {},
      "esp-prog": {},
      "iot-bus-jtag": {},
      "jlink": {},
      "minimodule": {},
      "olimex-arm-usb-tiny-h": {},
      "olimex-arm-usb-ocd-h": {},
      "olimex-arm-usb-ocd": {},
      "olimex-jtag-tiny": {},
      "tumpa": {}
    }
  },
  "build": {
    "extra_flags": "-DARDUINO_WT32_ETH01",
    "core": "esp32",
    "f_cpu": "240000000L",
    "mcu": "esp32",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "variant": "wt32-eth01",
    "arduino": {
      "ldscript": "esp32_out.ld"
    }
  },
  "upload": {
    "flash_size": "4MB",
    "speed": 460800,
    "require_upload_port": true
  }
}
