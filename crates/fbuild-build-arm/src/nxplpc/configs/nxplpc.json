{
  "name": "NXP LPC8xx",
  "description": "NXP LPC804 / LPC845 (ARM Cortex-M0+, bare-metal CMSIS)",
  "architecture": "arm-cortex-m0plus",
  "compiler_flags": {
    "common": [
      "-mcpu=cortex-m0plus",
      "-mthumb",
      "-fdata-sections",
      "-ffunction-sections",
      "-fno-exceptions",
      "-Wall",
      "-MMD"
    ],
    "c": [
      "-std=gnu11"
    ],
    "cxx": [
      "-std=gnu++11",
      "-fno-rtti",
      "-fno-use-cxa-atexit",
      "-fno-threadsafe-statics"
    ]
  },
  "linker_flags": [
    "-mcpu=cortex-m0plus",
    "-mthumb",
    "-specs=nano.specs",
    "-specs=nosys.specs",
    "-Wl,--gc-sections"
  ],
  "linker_libs": [
    "-Wl,--start-group",
    "-lc",
    "-lm",
    "-lgcc",
    "-lnosys",
    "-Wl,--end-group"
  ],
  "objcopy": {
    "output_format": "binary",
    "remove_sections": []
  },
  "profiles": {
    "release": {
      "compile_flags": ["-Os"],
      "link_flags": []
    },
    "quick": {
      "compile_flags": ["-Os"],
      "link_flags": []
    }
  },
  "defines": [
    "__NXPLPC__",
    "ARDUINO_ARCH_LPC8XX"
  ]
}
