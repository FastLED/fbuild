{
  "name": "STM32U5",
  "description": "STM32U5xx (ARM Cortex-M33F)",
  "architecture": "arm-cortex-m33",

  "compiler_flags": {
    "common": [
      "-mcpu=cortex-m33",
      "-mthumb",
      "-mfpu=fpv4-sp-d16",
      "-mfloat-abi=hard",
      "-Wall",
      "-Wextra",
      "-Wno-unused-parameter",
      "-ffunction-sections",
      "-fdata-sections",
      "-MMD",
      "--specs=nano.specs"
    ],
    "c": [
      "-std=gnu11"
    ],
    "cxx": [
      "-std=gnu++17",
      "-fno-exceptions",
      "-fno-rtti",
      "-fno-threadsafe-statics"
    ]
  },

  "linker_flags": [
    "-mcpu=cortex-m33",
    "-mthumb",
    "-mfpu=fpv4-sp-d16",
    "-mfloat-abi=hard",
    "-Wl,--gc-sections",
    "-Wl,--print-memory-usage",
    "--specs=nano.specs",
    "--specs=nosys.specs"
  ],

  "linker_libs": [
    "-lgcc",
    "-lstdc++",
    "-lm",
    "-lc"
  ],

  "objcopy": {
    "output_format": "ihex",
    "remove_sections": [".eeprom"]
  },

  "profiles": {
    "release": {
      "compile_flags": ["-Os", "-flto", "-fno-fat-lto-objects"],
      "link_flags": ["-flto", "-fuse-linker-plugin"]
    },
    "quick": {
      "compile_flags": ["-Os"],
      "link_flags": []
    }
  },

  "defines": [
    ["ARDUINO", "10808"]
  ]
}
