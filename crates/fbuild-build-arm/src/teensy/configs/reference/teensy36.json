{
  "board": "teensy36",
  "mcu": "mk66fx1m0",
  "platform": "teensy",
  "source": "PlatformIO teensy platform (extracted from platform_configs)",
  "compiler_flags": {
    "common": [
      "-mcpu=cortex-m4",
      "-mthumb",
      "-mfloat-abi=hard",
      "-mfpu=fpv4-sp-d16",
      "-Wall",
      "-ffunction-sections",
      "-fdata-sections",
      "-fsingle-precision-constant",
      "-MMD"
    ],
    "c": [
      "-std=gnu11"
    ],
    "cxx": [
      "-std=gnu++14",
      "-fno-exceptions",
      "-fno-rtti",
      "-felide-constructors",
      "-Wno-error=narrowing"
    ]
  },
  "defines": {
    "__MK66FX1M0__": "1",
    "ARDUINO_ARCH_TEENSY": "1",
    "ARDUINO_TEENSY36": "1",
    "ARDUINO": "10819",
    "TEENSYDUINO": "159",
    "F_BUS": "60000000",
    "USB_SERIAL": "1",
    "LAYOUT_US_ENGLISH": "1"
  },
  "linker_flags": [
    "-mcpu=cortex-m4",
    "-mthumb",
    "-mfloat-abi=hard",
    "-mfpu=fpv4-sp-d16",
    "-Wl,--gc-sections",
    "-Wl,--relax",
    "-Wl,--print-memory-usage",
    "-Wl,--defsym=__rtc_localtime=0",
    "--specs=nano.specs"
  ],
  "linker_libs": [
    "-lm",
    "-lstdc++",
    "-lc",
    "-lgcc"
  ]
}
